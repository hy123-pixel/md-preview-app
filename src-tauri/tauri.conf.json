{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Preview",
  "version": "0.1.2",
  "identifier": "com.dt.md-preview",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MD Preview",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/hy123-pixel/md-preview-app/releases/latest/download/latest.json"
      ],
      "pubkey": "RWQAAAAAAACVdLngzintm4Rc22wUoYP3q1Szj6IuJVdhYdeKiPRPAg==",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
